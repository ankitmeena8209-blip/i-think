# Persistent Cloud Database Configuration (Turso - Free Cloud SQLite)
# Set these on Vercel to make user data (users, thoughts, chats, admin) permanent across deployments
# TURSO_DATABASE_URL=libsql://i-think-yourname.turso.io
# TURSO_AUTH_TOKEN=your_turso_auth_token_here

# Admin Credentials
ADMIN_USER=admin
ADMIN_PASS=admin_secure_password

# Telegram Bot API Configuration
# Obtain your Bot Token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:YOUR_TELEGRAM_BOT_TOKEN_HERE

# Obtain your Chat ID by messaging @userinfobot or your channel/group ID
TELEGRAM_CHAT_ID=123456789
